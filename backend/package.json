{
  "name": "traceability-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test:contracts": "bun test src/lib/*.contract.test.js",
    "rules:validate": "bun run src/scripts/validate_rules.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:health": "bun run src/scripts/db-health.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@sinclair/typebox": "0.34.14",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "elysia": "1.1.27",
    "jose": "^6.1.3",
    "nodemailer": "^8.0.1",
    "postgres": "^3.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.5",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.3"
  }
}
