# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/traceability

# ── Auth (JWT) ────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret
REFRESH_TOKEN_SECRET=change-me-refresh-secret
DEVICE_TOKEN_SECRET=change-me-device-secret

# ── Seed Admin User ──────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# ── Timezone (Asia/Bangkok = UTC+7) ─────────────────────
TZ=Asia/Bangkok

# ── Server ───────────────────────────────────────────────
# HOST=0.0.0.0 to accept connections from LAN (default). Use 127.0.0.1 for local only.
HOST=0.0.0.0
PORT=3000

# Optional fallback SMTP (used only when DB settings are not configured yet)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURE=false
