## 3) 🗄 DB Schema

### Existing tables to modify

#### `material_request_status` enum — ADD values

```sql
ALTER TYPE material_request_status ADD VALUE 'PARTIALLY_RECEIVED';
ALTER TYPE material_request_status ADD VALUE 'INTAKE_COMPLETE';
```

### New tables

#### `handover_batches`

```sql
CREATE TYPE handover_batch_status AS ENUM (
  'PENDING', 'IN_TRANSIT', 'RECEIVED', 'RECEIVED_PARTIAL', 'CANCELLED'
);

CREATE TABLE handover_batches (
  id                UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  batch_no          VARCHAR(80) NOT NULL,                           -- HB-20260302-0001
  material_request_id UUID NOT NULL REFERENCES material_requests(id),
  issued_by_user_id UUID NOT NULL REFERENCES users(id),
  assigned_forklift_user_id UUID REFERENCES users(id),             -- nullable: auto or manual assign
  status            handover_batch_status NOT NULL DEFAULT 'PENDING',
  pickup_at         TIMESTAMPTZ,
  received_at       TIMESTAMPTZ,
  expected_item_count INTEGER NOT NULL DEFAULT 0,
  scanned_item_count  INTEGER NOT NULL DEFAULT 0,
  remarks           TEXT,
  created_at        TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_at        TIMESTAMPTZ NOT NULL DEFAULT now(),

  CONSTRAINT uq_handover_batch_no UNIQUE (batch_no)
);

CREATE INDEX idx_handover_batch_mr ON handover_batches(material_request_id);
CREATE INDEX idx_handover_batch_status ON handover_batches(status);
CREATE INDEX idx_handover_batch_forklift ON handover_batches(assigned_forklift_user_id);
```

#### `handover_batch_items` (links issue lines to batches)

```sql
CREATE TABLE handover_batch_items (
  id                  UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  handover_batch_id   UUID NOT NULL REFERENCES handover_batches(id) ON DELETE CASCADE,
  material_request_item_issue_id UUID NOT NULL REFERENCES material_request_item_issues(id),
  part_number         VARCHAR(120) NOT NULL,
  do_number           VARCHAR(120) NOT NULL,
  expected_packs      INTEGER NOT NULL,
  expected_qty        INTEGER NOT NULL,
  scanned_packs       INTEGER NOT NULL DEFAULT 0,
  scanned_qty         INTEGER NOT NULL DEFAULT 0,
  status              VARCHAR(30) NOT NULL DEFAULT 'PENDING',  -- PENDING | MATCHED | PARTIAL | OVER
  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),

  CONSTRAINT uq_hbi_issue UNIQUE (handover_batch_id, material_request_item_issue_id)
);

CREATE INDEX idx_hbi_batch ON handover_batch_items(handover_batch_id);
CREATE INDEX idx_hbi_part   ON handover_batch_items(part_number);
```

#### `scan_sessions`

```sql
CREATE TYPE scan_session_status AS ENUM ('OPEN', 'COMPLETED', 'ABANDONED');

CREATE TABLE scan_sessions (
  id                  UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  handover_batch_id   UUID NOT NULL REFERENCES handover_batches(id),
  user_id             UUID NOT NULL REFERENCES users(id),         -- forklift operator
  device_id           UUID REFERENCES devices(id),
  station_id          UUID,
  status              scan_session_status NOT NULL DEFAULT 'OPEN',
  started_at          TIMESTAMPTZ NOT NULL DEFAULT now(),
  finalized_at        TIMESTAMPTZ,
  total_scans         INTEGER NOT NULL DEFAULT 0,
  matched_scans       INTEGER NOT NULL DEFAULT 0,
  error_scans         INTEGER NOT NULL DEFAULT 0,
  remarks             TEXT,
  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now(),

  -- Only one OPEN session per batch at a time
  CONSTRAINT uq_open_session_per_batch UNIQUE (handover_batch_id, status)
    -- enforced via partial unique index below instead
);

-- Partial unique: only one OPEN session per batch
CREATE UNIQUE INDEX uq_scan_session_open
  ON scan_sessions(handover_batch_id)
  WHERE status = 'OPEN';

CREATE INDEX idx_scan_session_user ON scan_sessions(user_id);
CREATE INDEX idx_scan_session_batch ON scan_sessions(handover_batch_id);
```

#### `scan_events` (immutable audit log)

```sql
CREATE TYPE scan_event_result AS ENUM (
  'MATCHED', 'DUPLICATE', 'NOT_FOUND', 'EXPIRED', 'PARSE_ERROR', 'MISMATCH'
);

CREATE TABLE scan_events (
  id                  UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  idempotency_key     VARCHAR(80) NOT NULL,                      -- client-generated UUID
  scan_session_id     UUID NOT NULL REFERENCES scan_sessions(id),
  handover_batch_id   UUID NOT NULL REFERENCES handover_batches(id),
  barcode_raw         TEXT NOT NULL,
  parsed_supplier_code VARCHAR(80),
  parsed_part_number  VARCHAR(120),
  parsed_lot_number   VARCHAR(120),
  parsed_qty          INTEGER,
  parsed_uom          VARCHAR(30),
  parsed_expiry_date  DATE,
  parsed_production_date DATE,
  parsed_data         JSONB,                                     -- full parsed result
  result              scan_event_result NOT NULL,
  result_detail       TEXT,                                      -- human-readable error
  matched_batch_item_id UUID REFERENCES handover_batch_items(id),
  matched_supplier_pack_id UUID REFERENCES supplier_packs(id),
  user_id             UUID NOT NULL REFERENCES users(id),
  device_id           UUID REFERENCES devices(id),
  scanned_at_device   TIMESTAMPTZ NOT NULL,                      -- client timestamp
  received_at_server  TIMESTAMPTZ NOT NULL DEFAULT now(),
  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),

  CONSTRAINT uq_scan_event_idempotency UNIQUE (idempotency_key)
);

-- Prevent double-scan of same raw barcode within same MR
CREATE UNIQUE INDEX uq_scan_event_barcode_per_batch
  ON scan_events(handover_batch_id, barcode_raw)
  WHERE result = 'MATCHED';

CREATE INDEX idx_scan_event_session ON scan_events(scan_session_id);
CREATE INDEX idx_scan_event_batch   ON scan_events(handover_batch_id);
CREATE INDEX idx_scan_event_user    ON scan_events(user_id);
CREATE INDEX idx_scan_event_result  ON scan_events(result);
```

